{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "plansDirectory": ".claude/plans",
  "cleanupPeriodDays": 30,
  "attribution": { "commit": "assistant", "pr": "assistant" },

  "env": {
    "MUSTARD_SPEC_SIZE_MODE": "warn",
    "MUSTARD_SKILL_SIZE_MODE": "warn",
    "MUSTARD_SKILL_VALIDATE_LINES_MODE": "warn",
    "MUSTARD_CHECKLIST_GATE_MODE": "strict",
    "MUSTARD_BOUNDARY_MODE": "warn",
    "MUSTARD_MAIN_BUDGET_MODE": "warn",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4318",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "true",
    "MUSTARD_HARNESS_DUAL_EMIT": "1"
  },

  "mcpServers": {
    "mustard-memory": {
      "command": "bun",
      "args": ["dist/mcp/mustard-memory.js"],
      "env": { "MUSTARD_DB_PATH": ".claude/.harness/mustard.db" }
    }
  },

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Edit(.claude/**)",
      "Edit(**/.claude/**)",
      "Write",
      "Write(.claude/**)",
      "Write(**/.claude/**)",
      "Write(CLAUDE.md)",
      "Write(*/CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Edit(*/CLAUDE.md)",
      "Glob",
      "Grep",
      "Skill",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash",
      "Bash(bun .claude/scripts/event-projections.js:*)",
      "Bash(bun .claude/scripts/qa-run.js:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git restore .:*)",
      "Bash(chmod 777:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(format C:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check tool_use_counter",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check main_context_counter",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check bash_guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check size_gate",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "mustard-rt check close_gate",
            "timeout": 310
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check path_guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check enforce_registry",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check subagent_tracker",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check budget",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check model_routing",
            "timeout": 5
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check post_edit",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|Task|Agent|Read",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check metrics_tracker",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check skill_usage_tracker",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check bash_guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check budget",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-knowledge-inc.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "mustard-rt check subagent_tracker",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check skills_audit",
            "timeout": 3000
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/harness-init.js",
            "statusMessage": "Initializing harness event bus...",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "mustard-rt check subagent_tracker",
            "statusMessage": "Cleaning up previous session state...",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-memory.js",
            "statusMessage": "Loading persistent memory...",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/spec-hygiene.js",
            "statusMessage": "Auditing stale specs...",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "mustard-rt check tool_use_counter",
            "statusMessage": "Clearing tool budgets...",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check main_context_counter",
            "statusMessage": "Resetting delegation counter...",
            "timeout": 3
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact.js",
            "timeout": 10
          }
        ]
      }
    ],

    "SessionEnd": [
      {
        "matcher": "prompt_input_exit|clear|other",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-knowledge.js",
            "statusMessage": "Extracting session patterns...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/memory-auto-extract.js",
            "statusMessage": "Persisting decisions and lessons...",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-cleanup.js",
            "timeout": 5
          }
        ]
      }
    ],

    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check main_context_counter",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check subagent_tracker",
            "statusMessage": "Registering agent...",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check tool_use_counter",
            "statusMessage": "Initializing tool budget...",
            "timeout": 3
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mustard-rt check main_context_counter",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check subagent_tracker",
            "statusMessage": "Agent completed",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "mustard-rt check tool_use_counter",
            "timeout": 3
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/followup-cancel-gate.js",
            "timeout": 5000
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/scripts/statusline.js",
    "padding": 1
  }
}
