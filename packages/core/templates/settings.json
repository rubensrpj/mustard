{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "plansDirectory": ".claude/plans",
  "cleanupPeriodDays": 30,
  "attribution": {
    "commit": "assistant",
    "pr": "assistant"
  },
  "env": {
    "MUSTARD_SPEC_SIZE_MODE": "warn",
    "MUSTARD_SKILL_SIZE_MODE": "warn",
    "MUSTARD_SKILL_VALIDATE_LINES_MODE": "warn",
    "MUSTARD_CHECKLIST_GATE_MODE": "strict",
    "MUSTARD_BOUNDARY_MODE": "warn",
    "MUSTARD_MAIN_BUDGET_MODE": "warn",
    "MUSTARD_DELEGATION_WARN_MODE": "warn",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4318",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "true",
    "MUSTARD_HARNESS_DUAL_EMIT": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Edit(CLAUDE.md)",
      "Edit(*/CLAUDE.md)",
      "Glob",
      "Grep",
      "Skill",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash",
      "Bash(mustard-rt run event-projections:*)",
      "Bash(mustard-rt run qa-run:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)",
      "Bash(rm --no-preserve-root:*)",
      "Bash(rm -r /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset * --hard:*)",
      "Bash(git checkout -f:*)",
      "Bash(git checkout --force:*)",
      "Bash(git checkout * -f:*)",
      "Bash(git checkout * --force:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git restore .:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D main:*)",
      "Bash(git branch -D master:*)",
      "Bash(git branch -d main:*)",
      "Bash(git branch -d master:*)",
      "Bash(chmod 777:*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/*.pfx)",
      "Edit(**/*.pfx)",
      "Read(**/*.p12)",
      "Edit(**/*.p12)",
      "Read(**/*id_rsa*)",
      "Edit(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Edit(**/*id_ed25519*)",
      "Read(**/*credentials*)",
      "Edit(**/*credentials*)",
      "Read(**/.git/config)",
      "Edit(**/.git/config)",
      "Read(**/node_modules/**)",
      "Grep(**/node_modules/**)",
      "Read(**/bin/**)",
      "Grep(**/bin/**)",
      "Read(**/obj/**)",
      "Grep(**/obj/**)",
      "Read(**/dist/**)",
      "Grep(**/dist/**)",
      "Read(**/.next/**)",
      "Grep(**/.next/**)",
      "Read(**/__pycache__/**)",
      "Grep(**/__pycache__/**)",
      "Read(**/.venv/**)",
      "Grep(**/.venv/**)",
      "Read(**/venv/**)",
      "Grep(**/venv/**)",
      "Read(**/target/**)",
      "Grep(**/target/**)",
      "Read(**/build/**)",
      "Grep(**/build/**)",
      "Read(**/migrations/**)",
      "Grep(**/migrations/**)",
      "Read(**/Migrations/**)",
      "Grep(**/Migrations/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "mustard-rt run statusline",
    "padding": 1
  }
}
