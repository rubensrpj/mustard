{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "plansDirectory": ".claude/plans",
  "cleanupPeriodDays": 30,
  "attribution": { "commit": "assistant", "pr": "assistant" },

  "env": {
    "MUSTARD_SPEC_SIZE_MODE": "warn",
    "MUSTARD_SKILL_SIZE_MODE": "warn",
    "MUSTARD_SKILL_VALIDATE_LINES_MODE": "warn",
    "MUSTARD_CHECKLIST_GATE_MODE": "strict",
    "MUSTARD_BOUNDARY_MODE": "warn",
    "MUSTARD_MAIN_BUDGET_MODE": "warn",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4318",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "true",
    "MUSTARD_HARNESS_DUAL_EMIT": "1"
  },

  "mcpServers": {
    "mustard-memory": {
      "command": "mustard-rt",
      "args": ["mcp"],
      "env": { "MUSTARD_DB_PATH": ".claude/.harness/mustard.db" }
    }
  },

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Edit(.claude/**)",
      "Edit(**/.claude/**)",
      "Write",
      "Write(.claude/**)",
      "Write(**/.claude/**)",
      "Write(CLAUDE.md)",
      "Write(*/CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Edit(*/CLAUDE.md)",
      "Glob",
      "Grep",
      "Skill",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash",
      "Bash(mustard-rt run event-projections:*)",
      "Bash(mustard-rt run qa-run:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git restore .:*)",
      "Bash(chmod 777:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(format C:*)",
      "Read(**/node_modules/**)",
      "Grep(**/node_modules/**)",
      "Read(**/bin/**)",
      "Grep(**/bin/**)",
      "Read(**/obj/**)",
      "Grep(**/obj/**)",
      "Read(**/dist/**)",
      "Grep(**/dist/**)",
      "Read(**/.next/**)",
      "Grep(**/.next/**)",
      "Read(**/__pycache__/**)",
      "Grep(**/__pycache__/**)",
      "Read(**/.venv/**)",
      "Grep(**/.venv/**)",
      "Read(**/venv/**)",
      "Grep(**/venv/**)",
      "Read(**/target/**)",
      "Grep(**/target/**)",
      "Read(**/build/**)",
      "Grep(**/build/**)",
      "Read(**/migrations/**)",
      "Grep(**/migrations/**)",
      "Read(**/Migrations/**)",
      "Grep(**/Migrations/**)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on PreToolUse",
            "timeout": 310
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on PostToolUse",
            "timeout": 30
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on SessionStart",
            "statusMessage": "Initializing harness, memory, and budgets...",
            "timeout": 15
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on PreCompact",
            "timeout": 10
          }
        ]
      }
    ],

    "SessionEnd": [
      {
        "matcher": "prompt_input_exit|clear|other",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on SessionEnd",
            "statusMessage": "Extracting knowledge and cleaning state...",
            "timeout": 15
          }
        ]
      }
    ],

    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on SubagentStart",
            "statusMessage": "Registering agent...",
            "timeout": 5
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on SubagentStop",
            "statusMessage": "Agent completed",
            "timeout": 5
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "rtk mustard-rt on UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "mustard-rt run statusline",
    "padding": 1
  }
}
