# Synthetic, self-contained sample labels — illustrates the labels.ndjson
# format (see ../README.md). NO private data: these paths/queries are invented
# for a fictional commerce/billing domain. Each case is a recall-hole: the
# central query word shares NO token with the EN identifier, so name-match
# misses and only purpose-search (over the method's purpose summary) recovers it.
# Comment lines (#) and blank lines are skipped by the runner.

{"query": "quitar fatura em aberto", "files": ["src/Billing/InvoiceService.cs"], "lang": "pt-BR", "note": "SettleInvoiceAsync — 'quitar' diverge de 'Settle'"}
{"query": "efetivar previsão de pagamento", "files": ["src/Forecast/PaymentForecast.cs"], "lang": "pt-BR", "note": "EffectivateAsync — 'efetivar' invisível ao índice de nome"}
{"query": "estornar cobrança duplicada", "files": ["src/Payments/ChargeReversal.cs"], "lang": "pt-BR", "note": "ReverseChargeAsync — 'estornar' vs 'Reverse'"}
{"query": "conciliar extrato bancário", "files": ["src/Banking/StatementReconciler.cs"], "lang": "pt-BR", "note": "ReconcileAsync — 'conciliar' vs 'Reconcile'"}
{"query": "renovar assinatura mensal", "files": ["src/Subscriptions/SubscriptionRenewer.cs"], "lang": "pt-BR", "note": "RenewAsync — 'assinatura' vs 'Subscription'"}
