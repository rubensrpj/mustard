# Enforcement metrics (append-only, local telemetry)
.claude/.metrics/

# Agent runtime state (session-scoped)
.claude/.agent-state/

# Harness runtime state
.claude/.harness/

# Timestamped backups created by mustard init/update
.claude.backup.*/

# Dashboard runtime
.claude/.dashboard.pid
.claude/.dashboard.port
dashboard-html.txt

# Playwright MCP snapshots
.playwright-mcp/

# CLI template fixtures (regenerable runtime state)
packages/cli/templates/.claude/.harness/
packages/cli/templates/.claude/.metrics/
