{
  "git": {
    "flow": {
      "*": "dev",
      "dev": "main"
    },
    "provider": "github"
  },
  "buildCommand": "cargo build --workspace",
  "specLang": "en-US",
  "inject": [
    {
      "on": "userPromptSubmit",
      "file": ".claude/mustard/orchestrator.md",
      "once": true
    },
    {
      "on": "sessionStart",
      "file": ".claude/mustard/response-style.md",
      "once": true
    }
  ],
  "runtime": {
    "kind": "native",
    "os": "windows",
    "arch": "x86_64"
  },
  "version": "3.1.36"
}
